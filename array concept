public class Main {
    public static void main(String[] args) {
        int[] numbers = {10, 15, 22, 37, 48, 51};

        for (int i = 0; i < numbers.length; i++) {
            if (numbers[i] % 2 == 0) {
                System.out.println(numbers[i] + " is Even");
            } else {
                System.out.println(numbers[i] + " is Odd");
            }
        }
    }
}
